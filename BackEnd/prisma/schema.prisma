generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model no_show_charges {
  id             String       @id @default(dbgenerated("(uuid())")) @db.Char(36)
  reservation_id String       @unique(map: "reservation_id") @db.Char(36)
  user_id        String?      @db.Char(36)
  charge_amount  Decimal      @db.Decimal(10, 2)
  charge_status  String       @default("pending") @db.VarChar(20)
  charged_at     DateTime     @default(now()) @db.Timestamp(0)
  created_at     DateTime     @default(now()) @db.Timestamp(0)
  updated_at     DateTime     @default(now()) @db.Timestamp(0)
  reservations   reservations @relation(fields: [reservation_id], references: [id], onDelete: Cascade, map: "fk_no_show_charges_reservation")
  users          users?       @relation(fields: [user_id], references: [id], map: "fk_no_show_charges_user")

  @@index([user_id], map: "fk_no_show_charges_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payment_methods {
  id             String                       @id @default(dbgenerated("(uuid())")) @db.Char(36)
  user_id        String                       @db.Char(36)
  payment_type   payment_methods_payment_type
  card_last_four String?                      @db.VarChar(4)
  card_type      String?                      @db.VarChar(50)
  card_token     String?                      @db.Text
  is_default     Boolean                      @default(false)
  created_at     DateTime                     @default(now()) @db.Timestamp(0)
  updated_at     DateTime                     @default(now()) @db.Timestamp(0)
  users          users                        @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_payment_methods_user")

  @@index([user_id], map: "fk_payment_methods_user")
}

model reservation_tables {
  id                String            @id @default(dbgenerated("(uuid())")) @db.Char(36)
  reservation_id    String            @db.Char(36)
  table_id          String            @db.Char(36)
  created_at        DateTime          @default(now()) @db.Timestamp(0)
  reservations      reservations      @relation(fields: [reservation_id], references: [id], onDelete: Cascade, map: "fk_reservation_tables_reservation")
  restaurant_tables restaurant_tables @relation(fields: [table_id], references: [id], onDelete: Cascade, map: "fk_reservation_tables_table")

  @@unique([reservation_id, table_id], map: "uq_reservation_table")
  @@index([table_id], map: "fk_reservation_tables_table")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reservations {
  id                    String               @id @default(dbgenerated("(uuid())")) @db.Char(36)
  user_id               String?              @db.Char(36)
  guest_name            String?              @db.VarChar(255)
  guest_email           String?              @db.VarChar(255)
  guest_phone           String?              @db.VarChar(50)
  reservation_date      DateTime             @db.Date
  reservation_time      DateTime             @db.Time(0)
  number_of_guests      Int
  status                reservations_status? @default(PENDING)
  requires_holding_fee  Boolean              @default(false)
  holding_fee_paid      Boolean              @default(false)
  holding_fee_amount    Decimal              @default(0.00) @db.Decimal(10, 2)
  tables_need_combining Boolean              @default(false)
  special_requests      String?              @db.Text
  created_at            DateTime             @default(now()) @db.Timestamp(0)
  updated_at            DateTime             @default(now()) @db.Timestamp(0)
  no_show_charges       no_show_charges?
  reservation_tables    reservation_tables[]
  users                 users?               @relation(fields: [user_id], references: [id], map: "fk_reservations_user")
  transactions          transactions[]

  @@index([user_id], map: "fk_reservations_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model restaurant_tables {
  id                 String               @id @default(dbgenerated("(uuid())")) @db.Char(36)
  table_number       String               @unique(map: "table_number") @db.VarChar(50)
  capacity           Int
  is_active          Boolean?             @default(true)
  created_at         DateTime             @default(now()) @db.Timestamp(0)
  updated_at         DateTime             @default(now()) @db.Timestamp(0)
  reservation_tables reservation_tables[]
}

model special_days {
  id                     Int                       @id @default(autoincrement())
  description            String                    @db.VarChar(255)
  pattern_type           special_days_pattern_type
  month                  Int?                      @db.TinyInt
  day                    Int?                      @db.TinyInt
  weekday                Int?                      @db.TinyInt
  week_of_month          Int?                      @db.TinyInt
  exact_date             DateTime?                 @db.Date
  requires_holding_fee   Boolean                   @default(true)
  holding_fee_amount     Decimal                   @default(10.00) @db.Decimal(10, 2)
  no_show_penalty_amount Decimal                   @default(10.00) @db.Decimal(10, 2)
  is_active              Boolean                   @default(true)
  created_at             DateTime?                 @default(now()) @db.Timestamp(0)

  @@index([month], map: "idx_month")
  @@index([pattern_type], map: "idx_pattern")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model transactions {
  id               String                       @id @default(dbgenerated("(uuid())")) @db.Char(36)
  user_id          String?                      @db.Char(36)
  reservation_id   String?                      @db.Char(36)
  amount_spent     Decimal                      @db.Decimal(10, 2)
  points_earned    Int
  payment_method   transactions_payment_method?
  transaction_date DateTime                     @default(now()) @db.Timestamp(0)
  created_at       DateTime                     @default(now()) @db.Timestamp(0)
  reservations     reservations?                @relation(fields: [reservation_id], references: [id], map: "fk_transactions_reservation")
  users            users?                       @relation(fields: [user_id], references: [id], map: "fk_transactions_user")

  @@index([reservation_id], map: "fk_transactions_reservation")
  @@index([user_id], map: "fk_transactions_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id                       String                          @id @default(dbgenerated("(uuid())")) @db.Char(36)
  preferred_diner_number   String                          @unique(map: "preferred_diner_number") @db.VarChar(50)
  name                     String                          @db.VarChar(255)
  email                    String                          @unique(map: "email") @db.VarChar(255)
  phone                    String                          @db.VarChar(50)
  mailing_address          String?                         @db.Text
  billing_address          String?                         @db.Text
  billing_same_as_mailing  Boolean?                        @default(false)
  earned_points            Int?                            @default(0)
  preferred_payment_method users_preferred_payment_method?
  password_hash            String?                         @db.VarChar(255)
  created_at               DateTime?                       @default(now()) @db.Timestamp(0)
  updated_at               DateTime?                       @default(now()) @db.Timestamp(0)
  isRegistered             Boolean?                        @default(true)
  no_show_charges          no_show_charges[]
  payment_methods          payment_methods[]
  reservations             reservations[]
  transactions             transactions[]
}

enum special_days_pattern_type {
  fixed_annual
  nth_weekday_annual
  weekly
  exact_date
}

enum payment_methods_payment_type {
  CASH
  CREDIT
  CHECK
}

enum transactions_payment_method {
  CASH
  CREDIT
  CHECK
}

enum reservations_status {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum users_preferred_payment_method {
  CASH
  CREDIT
  CHECK
}
